# Copy this file to .env and fill in your values for production.
# Never commit the actual .env file to git.

# Flask secret key (use a long random string in production)
SECRET_KEY=your-super-secret-flask-key-here-change-this

# JWT signing key (use a long random string in production)
JWT_SECRET_KEY=your-super-secret-jwt-key-here-change-this

# Database URL
# SQLite (local dev):
# DATABASE_URL=sqlite:///chai_pe_charcha.db
# PostgreSQL (production, e.g. Render / Railway):
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///chai_pe_charcha.db

# Server port (Render sets this automatically)
PORT=5000
