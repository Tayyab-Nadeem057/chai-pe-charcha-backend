# Copy to .env and fill in real values. NEVER commit the real .env.
# Generate secrets with: python -c "import secrets; print(secrets.token_hex(32))"

# ── REQUIRED (app refuses to start without these) ──
SECRET_KEY=
JWT_SECRET_KEY=

# ── Database ──
# Local dev (SQLite):
DATABASE_URL=sqlite:///chai_pe_charcha.db
# Production (Postgres — Render/Railway/Neon/Supabase):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── CORS: exact frontend origin(s), comma-separated. No trailing slash. ──
# e.g. https://yourname.github.io  (your GitHub Pages site)
FRONTEND_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# ── Cookie security ──
# Cross-site (frontend and backend on different domains) needs None + secure.
# Same-site local dev over http: set JWT_COOKIE_SAMESITE=Lax, JWT_COOKIE_SECURE=false
JWT_COOKIE_SAMESITE=None
JWT_COOKIE_SECURE=true

# ── Uploads (optional override) ──
# UPLOAD_FOLDER=/var/data/uploads

# ── Rate limit storage (optional; use redis://... in production) ──
# RATELIMIT_STORAGE_URI=redis://localhost:6379

# ── WhatsApp OTP for password reset (Twilio) ──
# Without these, reset codes are printed to the logs (dev/test mode).
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── First-admin bootstrap (optional, no Shell needed) ──
# Set these and the first admin is created automatically on deploy (only when
# no users exist yet). Delete BOOTSTRAP_ADMIN_PASSWORD afterwards.
# BOOTSTRAP_ADMIN_NAME=Owner
# BOOTSTRAP_ADMIN_PHONE=03001234567
# BOOTSTRAP_ADMIN_PASSWORD=choose-a-strong-password

# Render sets PORT automatically
PORT=5000
